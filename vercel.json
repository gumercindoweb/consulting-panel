{
  "version": 2,
  "buildCommand": "pnpm run build",
  "devCommand": "pnpm run dev",
  "installCommand": "pnpm install",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "server/_core/index.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    { "src": "/trpc/(.*)", "dest": "server/_core/index.ts" },
    { "src": "/api/(.*)", "dest": "server/_core/index.ts" },
    { "src": "/(.*)", "dest": "dist/$1" }
  ]
}
