# ─── VARIABLES DE ENTORNO REQUERIDAS ──────────────────────────────────────
# Copiar a Vercel Settings > Environment Variables

# ─── Base de datos (PlanetScale)
# Crear BD en https://planetscale.com/ y copiar la connection string aquí
DATABASE_URL=mysql://username:password@region.connect.psdb.cloud/sensaciones-dashboard?sslaccept=strict

# ─── Autenticación JWT (para cookies de sesión)
# Generar una string aleatoria fuerte. Ej:
# openssl rand -hex 32
JWT_SECRET=your-random-secret-here-change-this

# ─── OAuth Manus (opcional; el login principal ahora es por email + clave)
# Estos pueden estar vacíos: el acceso de admin y clientes funciona con
# email + contraseña (ver scripts/set-password.mjs).
VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=dev-admin

# ─── Auto-login de desarrollo (opcional)
# Con DEV_AUTOLOGIN=1 entrás automáticamente como admin en local sin pasar por
# el login. Dejalo vacío/0 para probar el login real por email + clave.
DEV_AUTOLOGIN=

# ─── APIs opcionales
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ─── Node env
NODE_ENV=production
