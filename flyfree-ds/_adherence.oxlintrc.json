{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "ui_kits/ecommerce/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:FuturaStd|FuturaStdCondensed))/i]",
        "message": "Font not provided by the design system. Available: FuturaStd, FuturaStdCondensed."
      },
      {
        "selector": "JSXOpeningElement[name.name='Footer'] > JSXAttribute > JSXIdentifier[name!=/^(?:onNav|key|ref|className|style|children)$/]",
        "message": "<Footer> doesn't accept that prop. Declared props: onNav."
      },
      {
        "selector": "JSXOpeningElement[name.name='Header'] > JSXAttribute > JSXIdentifier[name!=/^(?:cartCount|onNav|key|ref|className|style|children)$/]",
        "message": "<Header> doesn't accept that prop. Declared props: cartCount, onNav."
      },
      {
        "selector": "JSXOpeningElement[name.name='Hero'] > JSXAttribute > JSXIdentifier[name!=/^(?:onShop|key|ref|className|style|children)$/]",
        "message": "<Hero> doesn't accept that prop. Declared props: onShop."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|category|price|badge|img|onAdd|onDetail|key|ref|className|style|children)$/]",
        "message": "<ProductCard> doesn't accept that prop. Declared props: name, category, price, badge, img, onAdd, onDetail."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Footer": {
        "replaces": []
      },
      "Header": {
        "replaces": []
      },
      "Hero": {
        "replaces": []
      },
      "ProductCard": {
        "replaces": []
      }
    },
